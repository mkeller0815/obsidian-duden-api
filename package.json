{
	"name": "duden-mentor",
	"version": "0.1.0",
	"description": "Obsidian plugin for spell and grammar checking via the Duden Mentor API",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc --noEmit -p tsconfig.json && node esbuild.config.mjs production",
		"lint": "eslint src --ext .ts"
	},
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@typescript-eslint/eslint-plugin": "^8.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.25.0",
		"eslint": "^9.0.0",
		"obsidian": "latest",
		"tslib": "^2.6.0",
		"typescript": "^5.8.0"
	}
}
